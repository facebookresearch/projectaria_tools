  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=22",
    "npm": "use yarn instead",
    "yarn": "^1.5"
  },
  "resolutions": {
    "@babel/plugin-transform-modules-systemjs": "^7.29.4",
